<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Videochamada 1:1</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/call.css" />
  </head>
  <body class="call-page">
    <main class="container py-4 py-lg-5">
      <header class="call-header mb-4">
        <div>
          <p class="section-label mb-1">Sala de atendimento</p>
          <h1 class="room-id h5 mb-0"><%= roomId %></h1>
        </div>
        <span id="connection-status" class="badge text-bg-secondary">Inicializando</span>
      </header>

      <section class="video-stage">
        <article class="video-card remote-card">
          <span class="video-tag">Participante</span>
          <video id="remote-video" autoplay playsinline></video>
          <div id="remote-placeholder" class="video-placeholder">Aguardando participante...</div>
          <div id="remote-media-state" class="remote-media-state"></div>
        </article>

        <article class="video-card local-card">
          <span class="video-tag">Você</span>
          <video id="local-video" autoplay muted playsinline></video>
        </article>
      </section>

      <section class="controls-panel mt-4">
        <div class="d-flex flex-wrap gap-2">
          <button id="toggle-audio-btn" class="btn btn-outline-light control-btn" type="button">
            Mic ligado
          </button>
          <button id="toggle-video-btn" class="btn btn-outline-light control-btn" type="button">
            Câmera ligada
          </button>
          <button id="enable-all-btn" class="btn btn-light control-btn" type="button">
            Ativar tudo
          </button>
          <button id="leave-btn" class="btn btn-danger control-btn ms-lg-auto" type="button">
            SAIR
          </button>
        </div>
      </section>

      <div id="feedback" class="alert alert-secondary mt-3 mb-0 small" role="status">
        Preparando acesso à câmera e microfone...
      </div>
    </main>

    <script>
      window.CALL_CONFIG = Object.freeze({
        roomId: <%- JSON.stringify(roomId) %>
      });
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/webrtc.js"></script>
  </body>
</html>
